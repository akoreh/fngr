{
  "name": "fngr",
  "version": "0.0.1",
  "description": "Modern gesture recognition library. PointerEvent-based, TypeScript-first, tree-shakeable, zero dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "Koreh Andrei",
  "repository": {
    "type": "git",
    "url": "https://github.com/AKoreh/fngr.git"
  },
  "keywords": [
    "gestures",
    "touch",
    "pointer",
    "tap",
    "swipe",
    "pan",
    "pinch",
    "rotate",
    "hammerjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./base": {
      "types": "./dist/core/base-recognizer.d.ts",
      "import": "./dist/core/base-recognizer.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "devDependencies": {
    "jsdom": "^29.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
